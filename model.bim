{
  "name": "aemo_electricity",
  "compatibilityLevel": 1604,
  "model": {
    "culture": "en-US",
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "annotations": [
      {
        "name": "PBI_ProTooling",
        "value": "[\"RemoteModeling\", \"DirectLakeOnOneLakeCreatedInDesktop\"]"
      }
    ],
    "expressions": [
      {
        "name": "DirectLake",
        "kind": "m",
        "expression": [
          "let",
          "    Source = AzureStorage.DataLake(\"{{ONELAKE_URL}}\", [HierarchicalNavigation=true])",
          "in",
          "    Source"
        ],
        "annotations": [
          {
            "name": "PBI_RemovedChildren",
            "value": "[{\"sourceLineageTag\":\"[aemo].[fct_scada]\"},{\"sourceLineageTag\":\"[aemo].[fct_scada_today]\"},{\"sourceLineageTag\":\"[aemo].[fct_price]\"},{\"sourceLineageTag\":\"[aemo].[fct_price_today]\"},{\"sourceLineageTag\":\"[aemo].[stg_csv_archive_log]\"}]"
          }
        ]
      }
    ],
    "tables": [
      {
        "name": "dim_calendar",
        "sourceLineageTag": "[aemo].[dim_calendar]",
        "columns": [
          {"name": "date", "dataType": "dateTime", "sourceColumn": "date", "isKey": true, "formatString": "yyyy-MM-dd", "sourceLineageTag": "date", "summarizeBy": "none"},
          {"name": "year", "dataType": "int64", "sourceColumn": "year", "sourceLineageTag": "year", "summarizeBy": "none"},
          {"name": "month", "dataType": "int64", "sourceColumn": "month", "sourceLineageTag": "month", "summarizeBy": "none"}
        ],
        "partitions": [
          {
            "name": "dim_calendar",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "dim_calendar",
              "expressionSource": "DirectLake",
              "schemaName": "aemo"
            }
          }
        ]
      },
      {
        "name": "dim_duid",
        "sourceLineageTag": "[aemo].[dim_duid]",
        "columns": [
          {"name": "DUID", "dataType": "string", "sourceColumn": "DUID", "isKey": true, "sourceLineageTag": "DUID", "summarizeBy": "none"},
          {"name": "Region", "dataType": "string", "sourceColumn": "Region", "sourceLineageTag": "Region", "summarizeBy": "none"},
          {"name": "State", "dataType": "string", "sourceColumn": "State", "sourceLineageTag": "State", "summarizeBy": "none"},
          {"name": "FuelSourceDescriptor", "dataType": "string", "sourceColumn": "FuelSourceDescriptor", "sourceLineageTag": "FuelSourceDescriptor", "summarizeBy": "none"},
          {"name": "Participant", "dataType": "string", "sourceColumn": "Participant", "sourceLineageTag": "Participant", "summarizeBy": "none"},
          {"name": "latitude", "dataType": "double", "sourceColumn": "latitude", "sourceLineageTag": "latitude", "summarizeBy": "none"},
          {"name": "longitude", "dataType": "double", "sourceColumn": "longitude", "sourceLineageTag": "longitude", "summarizeBy": "none"}
        ],
        "partitions": [
          {
            "name": "dim_duid",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "dim_duid",
              "expressionSource": "DirectLake",
              "schemaName": "aemo"
            }
          }
        ]
      },
      {
        "name": "fct_summary",
        "sourceLineageTag": "[aemo].[fct_summary]",
        "columns": [
          {"name": "date", "dataType": "dateTime", "sourceColumn": "date", "formatString": "yyyy-MM-dd", "sourceLineageTag": "date", "summarizeBy": "none"},
          {"name": "time", "dataType": "int64", "sourceColumn": "time", "sourceLineageTag": "time", "summarizeBy": "none"},
          {"name": "DUID", "dataType": "string", "sourceColumn": "DUID", "sourceLineageTag": "DUID", "summarizeBy": "none"},
          {"name": "mw", "dataType": "decimal", "sourceColumn": "mw", "formatString": "#,##0.00", "sourceLineageTag": "mw", "summarizeBy": "sum"},
          {"name": "price", "dataType": "decimal", "sourceColumn": "price", "formatString": "$#,##0.00", "sourceLineageTag": "price", "summarizeBy": "none"},
          {"name": "cutoff", "dataType": "dateTime", "sourceColumn": "cutoff", "formatString": "yyyy-MM-dd HH:mm", "sourceLineageTag": "cutoff", "summarizeBy": "none"}
        ],
        "measures": [
          {"name": "Total MW", "expression": "SUM(fct_summary[mw])", "formatString": "#,##0"},
          {"name": "Total MWh", "expression": "SUM(fct_summary[mw]) / 12", "formatString": "#,##0"},
          {"name": "Avg Price", "expression": "AVERAGE(fct_summary[price])", "formatString": "$#,##0.00"},
          {"name": "Generator Count", "expression": "DISTINCTCOUNT(fct_summary[DUID])", "formatString": "#,##0"},
          {"name": "Latest Update", "expression": "CALCULATE(MAX(fct_summary[cutoff]), REMOVEFILTERS())", "formatString": "yyyy-MM-dd HH:mm"}
        ],
        "partitions": [
          {
            "name": "fct_summary",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "fct_summary",
              "expressionSource": "DirectLake",
              "schemaName": "aemo"
            }
          }
        ]
      }
    ],
    "relationships": [
      {
        "fromTable": "fct_summary",
        "fromColumn": "DUID",
        "toTable": "dim_duid",
        "toColumn": "DUID",
        "relyOnReferentialIntegrity": true
      },
      {
        "fromTable": "fct_summary",
        "fromColumn": "date",
        "toTable": "dim_calendar",
        "toColumn": "date",
        "relyOnReferentialIntegrity": true
      }
    ]
  }
}
