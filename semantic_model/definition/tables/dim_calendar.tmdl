/// Calendar dimension covering 2018-04-01 to 2026-12-31.
/// Used to filter and aggregate electricity market data by date, month, and year.
table dim_calendar
	sourceLineageTag: [aemo].[dim_calendar]

	/// Calendar date (primary key). Grain: one row per day.
	column date
		dataType: dateTime
		isKey
		formatString: yyyy-MM-dd
		sourceColumn: date
		sourceLineageTag: date
		summarizeBy: none

	/// Calendar year (e.g. 2024)
	column year
		dataType: int64
		sourceColumn: year
		sourceLineageTag: year
		summarizeBy: none

	/// Calendar month number (1-12)
	column month
		dataType: int64
		sourceColumn: month
		sourceLineageTag: month
		summarizeBy: none

	partition dim_calendar = entity
		mode: directLake
		source
			entityName: dim_calendar
			expressionSource: DirectLake
			schemaName: aemo
