/// Direct Lake connection to OneLake — reads Delta tables directly, no SQL endpoint
expression DirectLake =
		let
			Source = AzureStorage.DataLake("{{ONELAKE_URL}}", [HierarchicalNavigation=true])
		in
			Source

	annotation PBI_RemovedChildren = [{"sourceLineageTag":"[aemo].[fct_scada]"},{"sourceLineageTag":"[aemo].[fct_scada_today]"},{"sourceLineageTag":"[aemo].[fct_price]"},{"sourceLineageTag":"[aemo].[fct_price_today]"},{"sourceLineageTag":"[aemo].[stg_csv_archive_log]"}]
